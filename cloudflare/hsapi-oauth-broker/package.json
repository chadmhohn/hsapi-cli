{
  "name": "@groundworkrevops/hsapi-oauth-broker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run types:check && npm run typecheck && npm test && npm run deploy:dry-run",
    "deploy:dry-run": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "deploy:production": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "dev": "wrangler dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types",
    "types:check": "wrangler types --check"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "@types/node": "^26.1.1",
    "typescript": "latest",
    "vitest": "^4.1.0",
    "wrangler": "4.112.0"
  }
}
